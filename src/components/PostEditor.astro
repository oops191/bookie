---
export interface Props {
  initialSlug?: string;
  initialTitle?: string;
  initialDescription?: string;
  initialContent?: string;
  initialDraft?: boolean;
  initialDate?: string;
  isNew: boolean;
}
---

<style>
  .editor-wrap {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .editor-meta {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .editor-meta input[type="text"],
  .editor-meta input[type="date"] {
    padding: 12px 16px;
    font-size: 1rem;
    font-family: inherit;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: transparent;
    color: var(--color-text);
    outline: none;
    transition: border-color var(--transition);
  }
  .editor-meta input:focus {
    border-color: var(--color-text-muted);
  }
  .meta-row {
    display: flex;
    gap: 12px;
    align-items: center;
  }
  .meta-row label {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
  }
  .meta-row input[type="checkbox"] {
    width: 16px;
    height: 16px;
    accent-color: var(--color-text);
    cursor: pointer;
  }
  .editor-panes {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    min-height: 60vh;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .editor-pane {
    padding: 24px;
    overflow-y: auto;
  }
  .editor-textarea {
    width: 100%;
    height: 100%;
    min-height: 400px;
    border: none;
    background: transparent;
    color: var(--color-text);
    font-family: "SF Mono", "Fira Code", "Consolas", monospace;
    font-size: 0.9rem;
    line-height: 1.7;
    resize: none;
    outline: none;
  }
  .editor-preview {
    background: var(--color-surface);
    font-size: 0.95rem;
    line-height: 1.8;
  }
  .editor-preview h1 { font-size: 1.8rem; margin-bottom: 0.8rem; }
  .editor-preview h2 { font-size: 1.3rem; margin-top: 1.5rem; margin-bottom: 0.6rem; }
  .editor-preview h3 { font-size: 1.1rem; margin-top: 1.2rem; margin-bottom: 0.5rem; }
  .editor-preview p { margin-bottom: 1rem; }
  .editor-preview ul, .editor-preview ol { margin-bottom: 1rem; padding-left: 1.5rem; }
  .editor-preview li { margin-bottom: 0.3rem; }
  .editor-preview blockquote {
    border-left: 3px solid var(--color-border);
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--color-text-secondary);
    font-style: italic;
  }
  .editor-preview code {
    background: var(--color-bg);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
  }
  .editor-preview pre {
    background: var(--color-bg);
    padding: 16px 20px;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 1rem;
  }
  .editor-preview pre code {
    background: none;
    padding: 0;
  }
  .editor-preview img { max-width: 100%; border-radius: 8px; }
  .editor-preview hr { border: none; border-top: 1px solid var(--color-border); margin: 1.5rem 0; }
  .editor-preview a { color: inherit; text-decoration: underline; }

  .editor-actions {
    display: flex;
    gap: 12px;
    align-items: center;
  }
  .save-btn {
    padding: 10px 24px;
    font-size: 0.95rem;
    font-family: inherit;
    font-weight: 600;
    border: none;
    border-radius: var(--radius);
    background: var(--color-text);
    color: var(--color-bg);
    cursor: pointer;
    transition: opacity var(--transition);
  }
  .save-btn:hover { opacity: 0.8; }
  .save-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .save-msg {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  .save-msg.success { color: #2e7d32; }
  .save-msg.error { color: #c62828; }
</style>

<div class="editor-wrap" id="editor-app">
  <div class="editor-meta">
    <input type="text" id="editor-title" placeholder="文章标题" value={Astro.props.initialTitle || ""} />
    <input type="text" id="editor-desc" placeholder="简短摘要" value={Astro.props.initialDescription || ""} />
    <div class="meta-row">
      <label>
        <input type="checkbox" id="editor-draft" checked={Astro.props.initialDraft || false} />
        草稿
      </label>
      <input type="date" id="editor-date" value={Astro.props.initialDate || ""} />
    </div>
  </div>

  <div class="editor-panes">
    <div class="editor-pane">
      <textarea id="editor-content" class="editor-textarea" placeholder="开始写 Markdown...">{Astro.props.initialContent || ""}</textarea>
    </div>
    <div class="editor-pane editor-preview" id="editor-preview"></div>
  </div>

  <div class="editor-actions">
    <button id="save-btn" class="save-btn">保存</button>
    <span id="save-msg" class="save-msg"></span>
  </div>
</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/marked@15/marked.min.js"></script>
<script is:inline>
  // @ts-ignore - loaded from CDN
  const marked = window.marked;

  const titleEl = document.getElementById("editor-title") as HTMLInputElement;
  const descEl = document.getElementById("editor-desc") as HTMLInputElement;
  const draftEl = document.getElementById("editor-draft") as HTMLInputElement;
  const dateEl = document.getElementById("editor-date") as HTMLInputElement;
  const contentEl = document.getElementById("editor-content") as HTMLTextAreaElement;
  const previewEl = document.getElementById("editor-preview")!;
  const saveBtn = document.getElementById("save-btn") as HTMLButtonElement;
  const saveMsg = document.getElementById("save-msg")!;

  const isNew = ${JSON.stringify(Astro.props.isNew)};
  const initialSlug = ${JSON.stringify(Astro.props.initialSlug || "")};

  function updatePreview() {
    previewEl.innerHTML = marked.parse(contentEl.value || "", { breaks: true });
  }

  contentEl.addEventListener("input", updatePreview);
  updatePreview();

  function generateSlug(title: string): string {
    return title
      .toLowerCase()
      .replace(/[^a-z0-9\u4e00-\u9fff]+/g, "-")
      .replace(/^-|-$/g, "")
      .slice(0, 60) || "untitled";
  }

  function showMessage(msg: string, type: "success" | "error" = "success") {
    saveMsg.textContent = msg;
    saveMsg.className = `save-msg ${type}`;
    if (type === "success") {
      setTimeout(() => { saveMsg.textContent = ""; }, 3000);
    }
  }

  saveBtn.addEventListener("click", async () => {
    const title = titleEl.value.trim();
    const description = descEl.value.trim();
    const content = contentEl.value;
    const draft = draftEl.checked;

    if (!title || !content) {
      showMessage("标题和内容不能为空", "error");
      return;
    }

    const slug = isNew ? generateSlug(title) : initialSlug;

    const body = {
      slug,
      title,
      description: description || title.slice(0, 100),
      content,
      draft,
    };

    saveBtn.disabled = true;
    saveBtn.textContent = "保存中...";

    try {
      const url = isNew ? "/api/posts" : `/api/posts/${initialSlug}`;
      const method = isNew ? "POST" : "PUT";
      const res = await fetch(url, {
        method,
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
      });

      if (res.ok) {
        showMessage("已保存 ✓");
        if (isNew) {
          const data = await res.json();
          window.location.href = `/admin/edit/${data.slug || slug}`;
        }
      } else {
        const data = await res.json();
        showMessage(data.error || "保存失败", "error");
      }
    } catch {
      showMessage("网络错误", "error");
    }

    saveBtn.disabled = false;
    saveBtn.textContent = "保存";
  });
</script>
