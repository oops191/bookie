---
import BaseLayout from "../../layouts/BaseLayout.astro";

interface Post {
  slug: string;
  title: string;
  description: string;
  content: string;
  draft: number;
  created_at: string;
  updated_at: string;
}

const db = Astro.locals.runtime.env.DB;
const { results } = await db.prepare("SELECT * FROM posts ORDER BY created_at DESC").all();
const posts = results as unknown as Post[];
---

<BaseLayout>
  <style>
    .dashboard-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 32px;
    }
    .dashboard-header h1 {
      font-size: 1.5rem;
    }
    .new-btn {
      padding: 10px 20px;
      font-size: 0.9rem;
      font-family: inherit;
      font-weight: 600;
      border: none;
      border-radius: var(--radius);
      background: var(--color-text);
      color: var(--color-bg);
      cursor: pointer;
      text-decoration: none;
      transition: opacity var(--transition);
      display: inline-block;
    }
    .new-btn:hover {
      opacity: 0.8;
    }
    .post-table {
      width: 100%;
      border-collapse: collapse;
    }
    .post-table th,
    .post-table td {
      text-align: left;
      padding: 14px 16px;
      border-bottom: 1px solid var(--color-border);
      font-size: 0.95rem;
    }
    .post-table th {
      color: var(--color-text-muted);
      font-weight: 500;
      font-size: 0.85rem;
    }
    .post-table td:last-child {
      text-align: right;
      white-space: nowrap;
    }
    .badge {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 600;
      padding: 2px 8px;
      border-radius: 6px;
    }
    .badge-published {
      background: #e8f5e9;
      color: #2e7d32;
    }
    .badge-draft {
      background: var(--color-surface);
      color: var(--color-text-muted);
    }
    [data-theme="dark"] .badge-published {
      background: #1b3a1b;
      color: #81c784;
    }
    .action-link {
      color: var(--color-text-secondary);
      text-decoration: none;
      font-size: 0.85rem;
      margin-left: 12px;
      transition: color var(--transition);
    }
    .action-link:hover {
      color: var(--color-text);
    }
    .action-link.danger {
      color: #c62828;
    }
    .action-link.danger:hover {
      color: #e53935;
    }
    .empty-state {
      text-align: center;
      padding: 60px 0;
      color: var(--color-text-muted);
    }
  </style>

  <div class="dashboard-header">
    <h1>文章管理</h1>
    <a href="/admin/new" class="new-btn">新建文章</a>
  </div>

  {posts.length === 0 ? (
    <div class="empty-state">
      <p>还没有文章，点击上方按钮创建第一篇。</p>
    </div>
  ) : (
    <table class="post-table">
      <thead>
        <tr>
          <th>标题</th>
          <th>日期</th>
          <th>状态</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody>
        {posts.map((post) => (
          <tr>
            <td>
              <a href={`/admin/edit/${post.slug}`} style="color:inherit;text-decoration:none;">
                {post.title}
              </a>
            </td>
            <td style="color:var(--color-text-secondary);">
              {new Date(post.created_at).toLocaleDateString("zh-CN", {
                year: "numeric",
                month: "2-digit",
                day: "2-digit",
              })}
            </td>
            <td>
              <span class={`badge ${post.draft ? "badge-draft" : "badge-published"}`}>
                {post.draft ? "草稿" : "已发布"}
              </span>
            </td>
            <td>
              <a href={`/admin/edit/${post.slug}`} class="action-link">编辑</a>
              <a href="#" class="action-link danger" data-slug={post.slug} data-action="delete">删除</a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  )}
</BaseLayout>

<script>
  document.querySelectorAll("[data-action='delete']").forEach((el) => {
    el.addEventListener("click", async (e) => {
      e.preventDefault();
      const slug = (e.target as HTMLElement).dataset.slug;
      if (!slug || !confirm(`确定要删除「${slug}」吗？此操作不可撤销。`)) return;

      const res = await fetch(`/api/posts/${slug}`, { method: "DELETE" });
      if (res.ok) {
        window.location.reload();
      } else {
        alert("删除失败");
      }
    });
  });
</script>
