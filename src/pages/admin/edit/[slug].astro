---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PostEditor from "../../../components/PostEditor.astro";
import type { Post } from "../../../lib/db";

const db = Astro.locals.runtime.env.DB;
const result = await db.prepare("SELECT * FROM posts WHERE slug = ?").bind(Astro.params.slug!).first();
const post = result as unknown as Post | null;

if (!post) {
  return Astro.redirect("/admin");
}
---

<BaseLayout>
  <a href="/admin" class="back-link" style="margin-bottom:24px;">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 18 9 12 15 6"/>
    </svg>
    返回仪表盘
  </a>
  <h1 style="font-size:1.5rem;margin-bottom:24px;">编辑文章</h1>
  <PostEditor
    isNew={false}
    initialSlug={post.slug}
    initialTitle={post.title}
    initialDescription={post.description}
    initialContent={post.content}
    initialDraft={post.draft === 1}
    initialDate={post.created_at.slice(0, 10)}
    client:load
  />
</BaseLayout>
